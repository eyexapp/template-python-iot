# Application
APP_NAME=myapp
APP_ENV=development
LOG_LEVEL=debug
LOCALE=en

# Hardware
MOCK_MODE=true
POLL_INTERVAL_SECONDS=5.0

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC_PREFIX=myapp/sensors

# Serial
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=9600

# HTTP (cloud API)
HTTP_ENDPOINT=http://localhost:8080/api/readings

# WebSocket
WS_URL=ws://localhost:8765

# Database
DB_PATH=data/sensors.db
